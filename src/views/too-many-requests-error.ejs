<div>
    <div class="fr-alert fr-alert--error fr-mb-2w">
        <p class="fr-alert__title">Accès temporairement limité.</p>
        <pre class="error-code">
            <%= error_message ;%>
        </pre>
        <p class="fr-mb-2w">
            Merci de ne pas retenter de connexion dans l’immédiat et de réessayer dans une <b>quinzaine de minutes</b>.
        </p>
    </div>
    <% if (locals.interactionId && locals.oidcError) { %>
        <a href="/interaction/<%= interactionId ;%>/error?error=<%= locals.oidcError %>" class="fr-btn btn--fullwidth">Continuer sur le service</a>
    <% } else { %>
        <a href="/" class="fr-btn btn--fullwidth">Retour à l’accueil</a>
    <% } %>
</div>
