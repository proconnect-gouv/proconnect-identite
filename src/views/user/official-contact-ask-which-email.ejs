<div>
    <%- include('../partials/notifications.ejs', {notifications: notifications, noWrapperDiv: true}) %>
    <div class="fr-mb-2w">
        <h1 class="fr-h3">
            Confirmer l'adresse email de contact
        </h1>
        <div>
            <form id="verify-email" method="GET" action="/users/official-contact-email-verification/<%= organization_id %>" autocomplete="off">
                <p>
                    Un code secret va être envoyé à l'adresse email officielle.
                </p>

                <p>À quelle adresse e-mail souhaitez-vous recevoir le code ?</p>

                <input type="hidden" name="_csrf" value="<%= csrfToken; %>" />


                <div class="fr-input-group">
                    <p class="fr-label" for="official_contact_email_verification_token">
                        Sélectionnez une adresse email
                    </p>
                   <ul>
                     <% contactEmails.forEach(function(email) { %>
                          <li>
                            <input type="radio" id="email-<%= email %>" name="contact_email" value="<%= email %>" required>
                            <label for="email-<%= email %>"><%= email %></label>
                          </li>
                     <% }); %>
                   </ul>
               
                </div>
                <%- include('../partials/submit-button.ejs', {label: 'Valider'}) %>
            
            </form>
            <%- include('../partials/go-back.ejs') %>
        </div>
    </div>
</div>
