<div>
    <%- include('../partials/stepper.ejs', {currentStep: "3", stepsTitle: "Demande en cours ⌛️", nextStepTitle: null }); %>
    <div>
      <div>
        <p class="fr-mb-0">Prénom</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= given_name; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                messageToDisplay: "Corriger ses informations personnelles",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <p class="fr-mb-0">Nom</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= family_name; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                messageToDisplay: "Corriger ses informations personnelles",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <p class="fr-mb-0">Email</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= email; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-sign-in/${moderation_id}`,
                messageToDisplay: "Corriger l'adresse email",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <p class="fr-mb-0">Rôle</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= job; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                messageToDisplay: "Corriger ses informations personnelles",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <div class="fr-tile fr-tile--horizontal fr-mb-2w fr-mt-2w">
          <div class="fr-tile__body">
              <h2 class="fr-tile__title">
                  <%= organization_label %>
              </h2>
              <% if (adresse) { %>
                  <p class="fr-tile__desc fr-pb-0"><%= adresse %></p>
              <% } %>
              <% if (siret) { %>
                  <p class="fr-tile__desc fr-pb-0"><b>SIRET : <%= siret %></b></p>
              <% } %>
          </div>
        </div>
        <form
          action="/users/cancel-moderation-and-redirect-to-join-org/<%= moderation_id %>"
          method="post"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken; %>" />
          <button 
            type="submit" 
            class="fr-btn btn--fullwidth fr-icon-edit-line fr-btn--icon-left fr-btn--tertiary js-confirm"
            data-confirm="Cette action annulera votre demande en cours. Voulez vous continuer ?"
            aria-label="Corriger l'organisation de rattachement"
            title="Corriger l'organisation de rattachement"
          >
            Changer d'organisation
          </button>
        </form>
      </div>
    </div>
</div>
<script type="module" src="<%= js('confirm.js') %>"></script>
