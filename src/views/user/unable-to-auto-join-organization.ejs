<div>
    <%- include('../partials/stepper.ejs', {currentStep: "3", stepsTitle: "Demande en cours ⌛️", nextStepTitle: null }); %>
    <div>
        <p class="fr-bold">
            <b>
                Nous vérifions votre lien à l’organisation, vous recevrez un email de confirmation dès que votre compte sera validé.
            </b>
        </p>
        <p>
            <i>
                (temps de traitement moyen : 1 jour ouvré)
            </i>
        </p>
    </div>
    <div class="border-shadow fr-p-2w">
        <h2 class="fr-h4">Récapitulatif de votre demande</h2>
        <div class="fr-grid-row centered-container-mobile">
            <p class="fr-mb-1w fr-mb-md-2w fr-mr-md-2w fr-badge fr-badge--info fr-badge--no-icon fr-col-4 centered-content">Prénom</p>
            <div class="fr-col-md-7 fr-col-12 fr-mb-2w">
                <span id="prenom-display"><b><%= given_name; %></b></span>
                <%- include(
                  '../partials/icon-edit-personal-info-form.ejs',
                  {
                    actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                    messageToDisplay: "Corriger le prénom",
                    confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
                  }
                ) %>
            </div>
            <p class="fr-mb-1w fr-mb-md-2w fr-mr-md-2w fr-badge fr-badge--info fr-badge--no-icon fr-col-4 centered-content">Nom</p>
            <div class="fr-col-md-7 fr-col-12 fr-mb-2w">
                <span >
                    <b><%= family_name; %></b>
                </span>
                <%- include(
                  '../partials/icon-edit-personal-info-form.ejs',
                  {
                    actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                    messageToDisplay: "Corriger le nom",
                    confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
                  }
                ) %>
            </div>
            <p class="fr-mb-1w fr-mb-md-2w fr-mr-md-2w fr-badge fr-badge--info fr-badge--no-icon fr-col-4 centered-content">Email</p>
            <div class="fr-col-md-7 fr-col-12 fr-mb-2w">
                <span ><b><%= email; %></b></span>
                <%- include(
                  '../partials/icon-edit-personal-info-form.ejs',
                  {
                    actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-sign-in/${moderation_id}`,
                    messageToDisplay: "Corriger l'adresse email",
                    confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
                  }
                ) %>

            </div>
            <p class="fr-mb-1w fr-mb-md-2w fr-mr-md-2w fr-badge fr-badge--info fr-badge--no-icon fr-col-4 centered-content">Organisation</p>
            <div class="fr-col-md-7 fr-col-12 fr-mb-2w">
                <span ><b><%= organization_label; %></b></span>
                <%- include(
                  '../partials/icon-edit-personal-info-form.ejs',
                  {
                    actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-join-org/${moderation_id}`,
                    messageToDisplay: "Corriger l'organisation de rattachement",
                    confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
                  }
                ) %>
            </div>
        </div>
        <p class="fr-mb-0">Nom</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= family_name; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                messageToDisplay: "Corriger ses informations personnelles",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <p class="fr-mb-0">Email</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= email; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-sign-in/${moderation_id}`,
                messageToDisplay: "Corriger l'adresse email",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <p class="fr-mb-0">Rôle</p>
        <div class="fr-grid-row fr-grid-row--middle">
          <div class="fr-col">
            <p class="fr-mb-2w"><b><%= job; %></b></p>
          </div>
          <div class="fr-col-auto">
            <%- include(
              '../partials/icon-edit-personal-info-form.ejs',
              {
                actionForUpdateModeration: `/users/cancel-moderation-and-redirect-to-personal-information/${moderation_id}`,
                messageToDisplay: "Corriger ses informations personnelles",
                confirmMessage: "Cette action annulera votre demande en cours. Voulez vous continuer ?"
              }
            ) %>
          </div>
        </div>
        <div class="fr-tile fr-tile--horizontal fr-mb-2w fr-mt-2w">
          <div class="fr-tile__body">
              <h2 class="fr-tile__title">
                  <%= organization_label %>
              </h2>
              <% if (adresse) { %>
                  <p class="fr-tile__desc fr-pb-0"><%= adresse %></p>
              <% } %>
              <% if (siret) { %>
                  <p class="fr-tile__desc fr-pb-0"><b>SIRET : <%= siret %></b></p>
              <% } %>
          </div>
        </div>
        <form
          action="/users/cancel-moderation-and-redirect-to-join-org/<%= moderation_id %>"
          method="post"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken; %>" />
          <button 
            type="submit" 
            class="fr-btn btn--fullwidth fr-icon-edit-line fr-btn--icon-left fr-btn--tertiary js-confirm"
            data-confirm="Cette action annulera votre demande en cours. Voulez vous continuer ?"
            aria-label="Corriger l'organisation de rattachement"
            title="Corriger l'organisation de rattachement"
          >
            Changer d'organisation
          </button>
        </form>
      </div>
    </div>
</div>
<script type="module" src="<%= js('confirm.js') %>"></script>
