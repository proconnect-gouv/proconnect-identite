<div>
    <h1 class="fr-h3">
        Votre organisation de rattachement
    </h1>
    <div>
        <p><span class="fr-label">Sélectionnez l’organisation dont vous faites partie</span></p>

        <div class="fr-grid-row">
            <% organizationSuggestions.forEach(({ id, siret, cached_libelle, cached_adresse, cached_libelle_activite_principale, cached_siege_social }) => { %>
            <div class="fr-col-12">
                <div id="submit-join-organization-<%= id %>" class="fr-tile fr-enlarge-link fr-tile--horizontal fr-mb-2w fr-px-2w fr-py-1w">
                    <div class="fr-tile__body">
                        <h2 class="fr-tile__title fr-mb-0 fr-text--lg">
                            <a class="fr-tile__link" href role="button" aria-label="Sélectionner l'organisation <%= cached_libelle; %>"><%= cached_libelle; %></a>
                        </h2>
                        <p class="fr-tile__desc fr-pb-0 fr-text--sm"><%= cached_adresse; %></p>
                        <p class="fr-tile__desc fr-pb-1v"><b>SIRET <%= siret; %></b></p>
                        <% if (typeof cached_siege_social === 'boolean') { %>
                            <p class="fr-tile__desc fr-pb-1w">
                                <span class="fr-badge fr-badge--no-icon <%= cached_siege_social ? 'fr-badge--info' : 'fr-badge--new' %>">
                                    <%= cached_siege_social ? "Siège social" : "Établissement secondaire"; %>
                                </span>
                            </p>
                        <% } %>
                    </div>
                </div>
                <form id="form-join-organization-<%= id %>" hidden action="/users/join-organization" method="post">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="siret" value="<%= siret %>">
                </form>
            </div>
            <% }); %>
        </div>
        <p class="fr-mb-0">
            <a
                href="/users/join-organization?do_not_propose_suggestions=true"
                class="fr-btn fr-btn--secondary btn--fullwidth"
            >
                Je veux rejoindre une autre organisation
            </a>
        </p>
    </div>
</div>
<script type="module" src="<%= js('submit-tile-forms.js') %>"></script>
