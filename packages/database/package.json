{
  "name": "@gouvfr-lasuite/proconnect.identite.database",
  "version": "0.0.0",
  "homepage": "https://github.com/proconnect-gouv/proconnect-identite/tree/master/packages/database#readme",
  "bugs": "https://github.com/proconnect-gouv/proconnect-identite/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proconnect-gouv/proconnect-identite.git",
    "directory": "packages/database"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#src/*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    }
  },
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "build:schema": "tsx ./scripts/build.ts",
    "check": "npm run build -- --noEmit",
    "dev": "npm run build -- --watch --preserveWatchOutput",
    "test": "npm run test:unit src/**/*.test.ts",
    "test:unit": "tsx --test --test-reporter=spec"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.8",
    "@gouvfr-lasuite/proconnect.devtools.typescript": "0.0.0",
    "@types/pg": "^8.15.5",
    "pg": "^8.16.3",
    "tsx": "^4.20.3",
    "zx": "^8.5.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
